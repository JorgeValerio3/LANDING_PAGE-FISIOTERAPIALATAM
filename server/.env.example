# Servidor
PORT=5000
NODE_ENV=development

# Seguridad
JWT_SECRET=tu_secreto_super_seguro_aqui_cambialo
CORS_ORIGIN=http://localhost:5173

# Base de Datos (MongoDB Atlas)
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombre_db>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/UFAAL_DB?retryWrites=true&w=majority

# Colección donde se guardarán los datos dinámicos
MONGODB_COLLECTION=app_data

# Cloudinary (Almacenamiento de Imágenes)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
